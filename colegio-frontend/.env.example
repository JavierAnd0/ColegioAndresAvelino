# ─────────────────────────────────────────────
#  COLEGIO FRONTEND — Variables de entorno
#  Copia este archivo como .env.local y rellena los valores reales.
#  NUNCA subas .env.local a Git.
# ─────────────────────────────────────────────

# URL base de la API del backend (sin slash al final)
# Desarrollo local:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Producción (ejemplo):
# NEXT_PUBLIC_API_URL=https://api.tucolegio.edu.co/api

# URL pública del sitio (para SEO, sitemap y robots.txt)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── EmailJS (formulario de contacto y reset de contraseña) ────
# Obtén estos valores en: https://www.emailjs.com → Account
NEXT_PUBLIC_EMAILJS_SERVICE_ID=tu_service_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=tu_public_key

# Template para el formulario de contacto
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=tu_template_contacto_id

# Template para el reset de contraseña del admin
NEXT_PUBLIC_EMAILJS_TEMPLATE_RESET_ID=tu_template_reset_id
