{
  "name": "colegio-backend",
  "version": "1.0.0",
  "description": "Backend API para sitio web del colegio",
  "main": "src/server.js",
  "type": "module",
  "nodemonConfig": {
    "nodeArgs": ["--import", "./src/instrument.mjs"]
  },
  "scripts": {
    "start": "node --import ./src/instrument.mjs src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seed.js",
    "reset-admin": "node src/utils/resetAdmin.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --detectOpenHandles",
    "test:verbose": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --detectOpenHandles --verbose"
  },
  "keywords": [
    "express",
    "mongodb",
    "api"
  ],
  "author": "Tu nombre",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
