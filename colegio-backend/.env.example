# ─────────────────────────────────────────────
#  COLEGIO BACKEND — Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env a Git.
# ─────────────────────────────────────────────

# Entorno: development | production | test
NODE_ENV=development

# Puerto del servidor Express
PORT=5000

# ── Base de datos ──────────────────────────────
# Cadena de conexión MongoDB Atlas (o local)
# Ejemplo local:   mongodb://localhost:27017/colegio
# Ejemplo Atlas:   mongodb+srv://usuario:password@cluster.mongodb.net/colegio
MONGODB_URI=mongodb://localhost:27017/colegio

# ── Autenticación JWT ──────────────────────────
# Clave secreta para firmar tokens — usa una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga
JWT_EXPIRE=7d

# ── Cloudinary (almacenamiento de imágenes) ────
# Obtén estos valores en: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── CORS ───────────────────────────────────────
# Orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3000

# ── URL del frontend ───────────────────────────
# Usado para generar links de reset de contraseña
FRONTEND_URL=http://localhost:3000

# ── Super administrador (seed inicial) ────────
# Se usa al ejecutar: npm run seed
SUPERADMIN_EMAIL=admin@colegio.edu.co
SUPERADMIN_PASSWORD=cambia_esta_contraseña
SUPERADMIN_NAME=Administrador

# ── Pexels API (búsqueda de imágenes) ─────────
# Opcional. Obtén tu clave en: https://www.pexels.com/api/
PEXELS_API_KEY=
